# METAai Organism Protocol — reference demo
# Copy to .env. The demo runs with NO real keys (mock LLM by default).

# Optional: set to use a real OpenAI-compatible endpoint instead of the mock LLM.
# Leave blank to use the built-in mock (recommended for the demo).
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=mock

# Demo server
HOST=127.0.0.1
PORT=8000
